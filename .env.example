# Reddit API（免费）
# 申请地址：https://www.reddit.com/prefs/apps → create another app → 选 script 类型
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=FCMobile Sentiment Monitor v1.0

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Slack Incoming Webhook（可选，不填则打印到 stdout）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# 监控目标（逗号分隔的 subreddit 名称）
SUBREDDITS=FUTMobile,EASportsFC

# Claude 模型
CLAUDE_MODEL=claude-haiku-4-5-20251001
