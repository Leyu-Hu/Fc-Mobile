# DeepSeek API（情感分析，OpenAI 兼容接口）
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-chat

# 收件人（多个用分号或逗号分隔）
REPORT_EMAIL_TO=someone@example.com; another@example.com

# SMTP 发件（默认 Gmail；SMTP_PASSWORD 用 Gmail 应用专用密码，不是登录密码）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# 监控分组：  分组名:subreddit1,subreddit2 | 下一组...
MONITOR_GROUPS=FC Mobile:FUTMobile|eFootball:eFootball
